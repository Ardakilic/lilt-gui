# Lilt GUI Environment Variables
# Copy this file to .env.local and customize as needed

# Development settings
NODE_ENV=development
VITE_APP_NAME=Lilt GUI
VITE_APP_VERSION=1.0.0

# Tauri settings
TAURI_DEBUG=true
TAURI_PLATFORM=

# API endpoints (if needed in future)
VITE_API_BASE_URL=

# Feature flags
VITE_ENABLE_DEBUG_LOGS=true
VITE_ENABLE_BETA_FEATURES=false

# Default paths (can be overridden by user settings)
VITE_DEFAULT_LILT_PATH=
VITE_DEFAULT_SOX_PATH=
VITE_DEFAULT_FFMPEG_PATH=

# Docker settings
VITE_DEFAULT_DOCKER_IMAGE=ardakilic/sox_ng:latest

# Telemetry and analytics (disabled by default)
VITE_ENABLE_TELEMETRY=false
VITE_ANALYTICS_ID=